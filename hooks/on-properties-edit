#!/usr/bin/env bash
set -euo pipefail

input=$(cat)

# Extract file_path from JSON using only grep/sed (no jq dependency)
# file_path values are filesystem paths and never contain quotes, so this is safe
file_path=$(printf '%s' "$input" | grep -o '"file_path"[[:space:]]*:[[:space:]]*"[^"]*"' | grep -o '[^"]*"$' | tr -d '"' || true)

if [ -z "$file_path" ] || ! printf '%s' "$file_path" | grep -qE 'application[^/\\]*\.yml$'; then
  exit 0
fi

filename=$(basename "$file_path")
cat <<EOF
{"systemMessage":"Modified $filename - run /azure-appconfig-migration:migrate to sync properties to Azure App Configuration.","hookSpecificOutput":{"hookEventName":"PostToolUse","additionalContext":"You modified a Spring Boot application config file. Remind the user to run /azure-appconfig-migration:migrate before committing."}}
EOF
