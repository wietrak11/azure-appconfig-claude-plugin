#!/usr/bin/env bash
set -euo pipefail

input=$(cat)

file_path=$(echo "$input" | jq -r '.tool_input.file_path // empty' 2>/dev/null || true)

if ! echo "$file_path" | grep -qE 'application[^/]*\.yml$'; then
  exit 0
fi

jq -n \
  --arg path "$file_path" \
  '{hookSpecificOutput: {hookEventName: "PostToolUse", additionalContext: ("You modified \($path). If you added or removed Spring Boot properties that belong in Azure App Configuration, run /azure-appconfig-migration:migrate before committing.")}}'
